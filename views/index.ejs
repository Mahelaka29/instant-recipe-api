<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Instant Recipe - Finder</title>
    <link rel="stylesheet" href="style/main.css" />
  </head>
  <body>
    <section class="hero">
      <header class="home-header">
        <a href="/" class="home-brand">Instant Recipe</a>
        <button type="button" class="nav-toggle" aria-label="Toggle navigation" aria-controls="home-nav" aria-expanded="false">
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
          <span class="nav-toggle-bar"></span>
        </button>
        <nav class="home-nav" id="home-nav">
          <% if (user) { %>
          <span class="home-nav-greeting">Hi, <%= user.username %></span>
          <a href="/favourites">My Favourite</a>
          <a href="/logout" onclick="return confirm('Are you sure you want to log out?');">Logout</a>
          <% } else { %>
          <a href="#" onclick="alert('Please log in to view your favourite recipes!'); window.location.href='/login'; return false;">My Favourite</a>
          <a href="/login">Login</a>
          <a href="/signup">Sign Up</a>
          <% } %>
        </nav>
      </header>
      <div class="overlay">
        <% if (loggedOut) { %>
        <script>alert("You have been logged out!");</script>
        <% } %>
        <div class="heading-wrapper">
          <h1 id="prompt-header">Craving Something?</h1>
        </div>
        <form action="/search" method="post" id="search_bar">
          <input type="text" name="food" id="search_food" placeholder="Search your favorite food..." />
          <input type="submit" value="Search" />
        </form>
        <p class="suggestions">Try: Pasta, Salad, Egg, Burger, Chocolate, and more...</p>
        <% if (errorMessage) { %>
        <div class="error"><%= errorMessage %></div>
        <% } %>
      </div>
    </section>
    <%- include('partials/footer') %>
    <script>
      (function () {
        var toggle = document.querySelector(".nav-toggle");
        var nav = document.getElementById("home-nav");
        if (!toggle || !nav) return;
        toggle.addEventListener("click", function () {
          var isOpen = nav.classList.toggle("is-open");
          toggle.setAttribute("aria-expanded", isOpen ? "true" : "false");
        });
        nav.querySelectorAll("a").forEach(function (link) {
          link.addEventListener("click", function () {
            nav.classList.remove("is-open");
            toggle.setAttribute("aria-expanded", "false");
          });
        });
      })();
    </script>
  </body>
</html>